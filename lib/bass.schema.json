{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://buildaistartups.com/schemas/bass/v0.1",
  "title": "BASS - Build AI Startups Spec",
  "description": "Build AI Startups Specification v0.1",
  "type": "object",
  "required": ["version", "projectId", "metadata", "product", "ai", "metrics"],
  "properties": {
    "version": {
      "type": "string",
      "enum": ["0.1"],
      "description": "BASS schema version"
    },
    "projectId": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 3,
      "maxLength": 50,
      "description": "Unique project identifier"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "description", "stage", "vertical", "createdAt", "updatedAt"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "stage": {
          "type": "string",
          "enum": ["ideation", "validation", "mvp", "growth", "scale", "maturity"]
        },
        "vertical": {
          "type": "string",
          "enum": ["ai-leadgen", "ai-support", "ai-analytics", "ai-automation", "ai-content", "ai-finance", "ai-health", "ai-education", "other"]
        },
        "teamSize": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "fundingStage": {
          "type": "string",
          "enum": ["pre-seed", "seed", "series-a", "series-b", "series-c", "ipo", "bootstrapped"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "maxItems": 10
        }
      }
    },
    "product": {
      "type": "object",
      "required": ["problem", "solution", "targetMarket", "valueProposition"],
      "properties": {
        "problem": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1000
        },
        "solution": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1000
        },
        "targetMarket": {
          "type": "object",
          "required": ["segments", "tam", "sam", "som"],
          "properties": {
            "segments": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1,
              "maxItems": 10
            },
            "tam": {
              "type": "number",
              "minimum": 0,
              "description": "Total Addressable Market in USD"
            },
            "sam": {
              "type": "number",
              "minimum": 0,
              "description": "Serviceable Addressable Market in USD"
            },
            "som": {
              "type": "number",
              "minimum": 0,
              "description": "Serviceable Obtainable Market in USD"
            },
            "geography": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "valueProposition": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500
        },
        "competitiveAdvantage": {
          "type": "string",
          "maxLength": 1000
        },
        "businessModel": {
          "type": "string",
          "enum": ["b2b-saas", "b2c-subscription", "marketplace", "api", "freemium", "enterprise", "usage-based", "hybrid"]
        },
        "pricing": {
          "type": "object",
          "properties": {
            "model": {
              "type": "string",
              "enum": ["subscription", "usage", "flat", "tiered", "freemium", "custom"]
            },
            "tiers": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "price"],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "price": {
                    "type": "number",
                    "minimum": 0
                  },
                  "features": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "ai": {
      "type": "object",
      "required": ["models", "dataStrategy", "evalPolicy", "safety"],
      "properties": {
        "models": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "provider", "purpose", "version"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Model name (e.g., gpt-4, claude-3)"
              },
              "provider": {
                "type": "string",
                "enum": ["openai", "anthropic", "google", "meta", "mistral", "cohere", "huggingface", "replicate", "custom"]
              },
              "purpose": {
                "type": "string",
                "description": "Primary use case for this model"
              },
              "version": {
                "type": "string"
              },
              "fineTuned": {
                "type": "boolean",
                "default": false
              },
              "deployment": {
                "type": "string",
                "enum": ["api", "self-hosted", "edge", "embedded"]
              },
              "costPerMillionTokens": {
                "type": "object",
                "properties": {
                  "input": {
                    "type": "number",
                    "minimum": 0
                  },
                  "output": {
                    "type": "number",
                    "minimum": 0
                  }
                }
              }
            }
          }
        },
        "retrieval": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "vectorStore": {
              "type": "string",
              "enum": ["pinecone", "weaviate", "chroma", "qdrant", "milvus", "pgvector", "redis", "custom"]
            },
            "embeddingModel": {
              "type": "string"
            },
            "chunkSize": {
              "type": "integer",
              "minimum": 100,
              "maximum": 10000
            },
            "topK": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "dataSources": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type", "name"],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["documents", "api", "database", "web", "custom"]
                  },
                  "name": {
                    "type": "string"
                  },
                  "updateFrequency": {
                    "type": "string",
                    "enum": ["realtime", "hourly", "daily", "weekly", "monthly", "manual"]
                  }
                }
              }
            }
          }
        },
        "dataStrategy": {
          "type": "object",
          "required": ["collection", "privacy", "retention"],
          "properties": {
            "collection": {
              "type": "string",
              "enum": ["minimal", "standard", "comprehensive"]
            },
            "privacy": {
              "type": "object",
              "required": ["gdprCompliant", "ccpaCompliant", "dataEncryption"],
              "properties": {
                "gdprCompliant": {
                  "type": "boolean"
                },
                "ccpaCompliant": {
                  "type": "boolean"
                },
                "dataEncryption": {
                  "type": "boolean"
                },
                "anonymization": {
                  "type": "boolean"
                }
              }
            },
            "retention": {
              "type": "object",
              "required": ["days"],
              "properties": {
                "days": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 3650
                },
                "policy": {
                  "type": "string"
                }
              }
            },
            "training": {
              "type": "object",
              "properties": {
                "userDataForTraining": {
                  "type": "boolean",
                  "default": false
                },
                "syntheticDataGeneration": {
                  "type": "boolean",
                  "default": false
                }
              }
            }
          }
        },
        "evalPolicy": {
          "type": "object",
          "required": ["frequency", "metrics", "thresholds"],
          "properties": {
            "frequency": {
              "type": "string",
              "enum": ["continuous", "daily", "weekly", "monthly", "quarterly"]
            },
            "metrics": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": ["accuracy", "latency", "cost", "user-satisfaction", "safety", "bias", "hallucination", "relevance", "coherence", "custom"]
              }
            },
            "thresholds": {
              "type": "object",
              "properties": {
                "accuracy": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "latencyMs": {
                  "type": "integer",
                  "minimum": 0
                },
                "costPerRequest": {
                  "type": "number",
                  "minimum": 0
                },
                "safetyScore": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            },
            "humanInLoop": {
              "type": "boolean",
              "default": false
            },
            "automatedTesting": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "safety": {
          "type": "object",
          "required": ["contentFiltering", "monitoring", "fallback"],
          "properties": {
            "contentFiltering": {
              "type": "object",
              "required": ["enabled", "categories"],
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "categories": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": ["hate", "violence", "sexual", "self-harm", "pii", "misinformation", "copyright", "custom"]
                  }
                },
                "threshold": {
                  "type": "string",
                  "enum": ["strict", "moderate", "minimal"]
                }
              }
            },
            "monitoring": {
              "type": "object",
              "required": ["realtime", "logging"],
              "properties": {
                "realtime": {
                  "type": "boolean"
                },
                "logging": {
                  "type": "string",
                  "enum": ["none", "errors", "warnings", "info", "debug", "all"]
                },
                "alerting": {
                  "type": "boolean",
                  "default": true
                }
              }
            },
            "fallback": {
              "type": "object",
              "required": ["strategy"],
              "properties": {
                "strategy": {
                  "type": "string",
                  "enum": ["graceful-degradation", "manual-review", "alternative-model", "error-message"]
                },
                "message": {
                  "type": "string"
                }
              }
            },
            "redTeaming": {
              "type": "boolean",
              "default": false
            },
            "biasDetection": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type", "capabilities"],
            "properties": {
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": ["conversational", "task", "autonomous", "collaborative", "specialized"]
              },
              "capabilities": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "tools": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "autonomyLevel": {
                "type": "string",
                "enum": ["none", "low", "medium", "high", "full"]
              }
            }
          }
        }
      }
    },
    "pages": {
      "type": "object",
      "properties": {
        "frontPorch": {
          "type": "object",
          "properties": {
            "start": {
              "$ref": "#/definitions/pageStatus"
            },
            "validate": {
              "$ref": "#/definitions/pageStatus"
            },
            "plan": {
              "$ref": "#/definitions/pageStatus"
            }
          }
        },
        "core": {
          "type": "object",
          "properties": {
            "builder": {
              "$ref": "#/definitions/pageStatus"
            },
            "ecosystem": {
              "$ref": "#/definitions/pageStatus"
            },
            "marketplace": {
              "$ref": "#/definitions/pageStatus"
            },
            "api": {
              "$ref": "#/definitions/pageStatus"
            }
          }
        },
        "backPorch": {
          "type": "object",
          "properties": {
            "grow": {
              "$ref": "#/definitions/pageStatus"
            },
            "finance": {
              "$ref": "#/definitions/pageStatus"
            },
            "evals": {
              "$ref": "#/definitions/pageStatus"
            },
            "investor": {
              "$ref": "#/definitions/pageStatus"
            }
          }
        },
        "lanes": {
          "type": "object",
          "properties": {
            "product": {
              "$ref": "#/definitions/pageStatus"
            },
            "market": {
              "$ref": "#/definitions/pageStatus"
            },
            "growth": {
              "$ref": "#/definitions/pageStatus"
            },
            "opsLegal": {
              "$ref": "#/definitions/pageStatus"
            }
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "required": ["buildScore", "financial", "operational"],
      "properties": {
        "buildScore": {
          "type": "object",
          "required": ["overall", "components"],
          "properties": {
            "overall": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "components": {
              "type": "object",
              "required": ["product", "market", "team", "execution", "finance"],
              "properties": {
                "product": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100
                },
                "market": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100
                },
                "team": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100
                },
                "execution": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100
                },
                "finance": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100
                }
              }
            },
            "trend": {
              "type": "string",
              "enum": ["up", "stable", "down"]
            },
            "lastUpdated": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "financial": {
          "type": "object",
          "properties": {
            "mrr": {
              "type": "number",
              "minimum": 0,
              "description": "Monthly Recurring Revenue"
            },
            "arr": {
              "type": "number",
              "minimum": 0,
              "description": "Annual Recurring Revenue"
            },
            "burnRate": {
              "type": "number",
              "description": "Monthly burn rate"
            },
            "runway": {
              "type": "integer",
              "minimum": 0,
              "description": "Runway in months"
            },
            "ltv": {
              "type": "number",
              "minimum": 0,
              "description": "Customer Lifetime Value"
            },
            "cac": {
              "type": "number",
              "minimum": 0,
              "description": "Customer Acquisition Cost"
            },
            "grossMargin": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "operational": {
          "type": "object",
          "properties": {
            "users": {
              "type": "object",
              "properties": {
                "total": {
                  "type": "integer",
                  "minimum": 0
                },
                "active": {
                  "type": "integer",
                  "minimum": 0
                },
                "paid": {
                  "type": "integer",
                  "minimum": 0
                },
                "churn": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "nps": {
                  "type": "integer",
                  "minimum": -100,
                  "maximum": 100
                }
              }
            },
            "ai": {
              "type": "object",
              "properties": {
                "requestsPerDay": {
                  "type": "integer",
                  "minimum": 0
                },
                "avgLatencyMs": {
                  "type": "number",
                  "minimum": 0
                },
                "errorRate": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "tokenUsage": {
                  "type": "object",
                  "properties": {
                    "daily": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "monthly": {
                      "type": "integer",
                      "minimum": 0
                    }
                  }
                },
                "modelCosts": {
                  "type": "object",
                  "properties": {
                    "daily": {
                      "type": "number",
                      "minimum": 0
                    },
                    "monthly": {
                      "type": "number",
                      "minimum": 0
                    }
                  }
                }
              }
            }
          }
        },
        "growth": {
          "type": "object",
          "properties": {
            "momGrowth": {
              "type": "number",
              "description": "Month-over-month growth rate"
            },
            "yoyGrowth": {
              "type": "number",
              "description": "Year-over-year growth rate"
            },
            "viralCoefficient": {
              "type": "number",
              "minimum": 0
            },
            "referralRate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      }
    },
    "finance": {
      "type": "object",
      "properties": {
        "grants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "amount", "status"],
            "properties": {
              "name": {
                "type": "string"
              },
              "provider": {
                "type": "string"
              },
              "amount": {
                "type": "number",
                "minimum": 0
              },
              "status": {
                "type": "string",
                "enum": ["researching", "applied", "approved", "rejected", "received"]
              },
              "deadline": {
                "type": "string",
                "format": "date"
              }
            }
          }
        },
        "funding": {
          "type": "object",
          "properties": {
            "raised": {
              "type": "number",
              "minimum": 0
            },
            "rounds": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type", "amount", "date"],
                "properties": {
                  "type": {
                    "type": "string"
                  },
                  "amount": {
                    "type": "number",
                    "minimum": 0
                  },
                  "date": {
                    "type": "string",
                    "format": "date"
                  },
                  "investors": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "valuation": {
                    "type": "number",
                    "minimum": 0
                  }
                }
              }
            }
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "title", "date"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["customer", "revenue", "partnership", "award", "milestone", "press", "testimonial"]
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "date": {
                "type": "string",
                "format": "date"
              },
              "value": {
                "type": "number"
              },
              "verified": {
                "type": "boolean",
                "default": false
              }
            }
          }
        }
      }
    },
    "roadmap": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["milestone", "targetDate", "status"],
        "properties": {
          "milestone": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "targetDate": {
            "type": "string",
            "format": "date"
          },
          "status": {
            "type": "string",
            "enum": ["planned", "in-progress", "completed", "delayed", "cancelled"]
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "kpis": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["metric", "target"],
              "properties": {
                "metric": {
                  "type": "string"
                },
                "target": {
                  "type": "number"
                },
                "current": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    },
    "responsibleAI": {
      "type": "object",
      "properties": {
        "principles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ethicsBoard": {
          "type": "boolean",
          "default": false
        },
        "transparencyReport": {
          "type": "boolean",
          "default": false
        },
        "biasAudits": {
          "type": "object",
          "properties": {
            "frequency": {
              "type": "string",
              "enum": ["never", "quarterly", "monthly", "continuous"]
            },
            "lastAudit": {
              "type": "string",
              "format": "date"
            }
          }
        },
        "dataGovernance": {
          "type": "object",
          "properties": {
            "policy": {
              "type": "boolean"
            },
            "officer": {
              "type": "boolean"
            },
            "training": {
              "type": "boolean"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "pageStatus": {
      "type": "object",
      "properties": {
        "complete": {
          "type": "boolean",
          "default": false
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "lastUpdated": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
